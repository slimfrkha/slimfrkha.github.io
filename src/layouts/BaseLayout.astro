---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = site.summary } = Astro.props;
const pageTitle = title ? `${title} · ${site.name}` : `${site.name} — ${site.role}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      // Flag JS so reveal styles apply only when they can be undone.
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <Nav />
    <main class="wrap">
      <slot />
    </main>
    <Footer />
    <script>
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Scroll-reveal: fade sections in once as they enter view.
      const revealables = document.querySelectorAll('.reveal');
      if (reduce) {
        revealables.forEach((el) => el.classList.add('is-visible'));
      } else {
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -12% 0px' },
        );
        revealables.forEach((el) => revealObserver.observe(el));
      }

      // Scrollspy: highlight a nav link only while its own section is in view.
      // Sections that aren't in the menu (Patents, Talks, …) clear the highlight.
      const navLinks = new Map(
        [...document.querySelectorAll('.nav .links a[href*="#"]')].map((a) => [
          a.getAttribute('href').split('#')[1],
          a,
        ]),
      );
      const sections = [...document.querySelectorAll('main section[id]')];
      const visible = new Set();
      const spy = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) visible.add(entry.target.id);
            else visible.delete(entry.target.id);
          });
          const activeId = sections.find((s) => visible.has(s.id))?.id;
          navLinks.forEach((l) => l.classList.remove('active'));
          if (activeId && navLinks.has(activeId)) {
            navLinks.get(activeId).classList.add('active');
          }
        },
        { rootMargin: '-45% 0px -50% 0px' },
      );
      sections.forEach((section) => spy.observe(section));
    </script>
  </body>
</html>
